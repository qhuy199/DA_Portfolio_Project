{
  "name": "QuangHuy IT Dashboard",
  "dataColors": [
    "#1ABC9C",
    "#2ECC71",
    "#9B59B6",
    "#F39C12",
    "#3498DB",
    "#E74C3C",
    "#27AE60",
    "#8E44AD"
  ],
  "background": "#F0F4F0",
  "foreground": "#2C3E50",
  "tableAccent": "#1ABC9C",
  "visualStyles": {
